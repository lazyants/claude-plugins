{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-marketplace.local/literary-translator/schemas/profile.schema.json",
  "title": "literary-translator profile.yml",
  "description": "Structural contract for .claude/literary-translator/profile.yml. Shape/type/enum/conditional validation only -- filesystem existence, path-traversal safety, and placeholder-substring rejection are procedural checks done by profile_validate.py, not this schema.",
  "type": "object",
  "properties": {
    "profile_version": {
      "const": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "durable_root", "pipeline_version", "max_segment_words"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "durable_root": {
          "type": "string",
          "minLength": 1
        },
        "durable_root_adopt_existing": {
          "type": "boolean"
        },
        "pipeline_version": {
          "type": "string",
          "minLength": 1
        },
        "max_segment_words": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "path", "language", "adapter_config"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["gutenberg_epub", "plain_text", "custom"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "gutenberg_id": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "language": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "particle_config", "smoke_test"],
          "properties": {
            "code": {
              "type": "string",
              "pattern": "^[a-z]{2}$"
            },
            "particle_config": {
              "type": "string",
              "minLength": 6,
              "pattern": "^[A-Za-z0-9_.-]+\\.json$"
            },
            "smoke_test": {
              "type": "object",
              "additionalProperties": false,
              "required": ["report_path"],
              "properties": {
                "report_path": {
                  "type": ["string", "null"]
                }
              }
            }
          }
        },
        "conservation": {
          "description": "Opt-in (#196/#202 content-conservation gate, validate_conservation.py). Absent -- the common case, most projects are not a hand-wrap -- means the wrapper-conservation check is a documented SKIP, never a forced-on hard gate. Only declare this for a source hand-wrapped into this project's format from some other pre-wrap form (e.g. pdftotext -layout output split into an EPUB by hand), where the exact pre-wrap text has been preserved as an immutable baseline. All three paths are durable-root-relative (no absolute path, no '..' segment -- path-traversal safety, checked procedurally by validate_conservation.py, not this schema).",
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["baseline_path", "provenance_path"],
          "properties": {
            "baseline_path": {
              "description": "The exact pre-wrap source text the wrap was made from, preserved verbatim.",
              "type": "string",
              "minLength": 1
            },
            "provenance_path": {
              "description": "JSON map, built at wrap time, of baseline character spans -> manifest block_id -- see validate_conservation.py's own module docstring for the exact shape.",
              "type": "string",
              "minLength": 1
            },
            "allowed_omissions_path": {
              "description": "Optional JSON file of line-regexes and half-open CHARACTER-offset (Unicode code point, never UTF-8 byte) ranges (front matter, running heads, page numbers) the coverage-gap check tolerates as legitimately un-provenanced. Same coordinate system as provenance_path's baseline_start/baseline_end -- do not compute these with a byte-counting tool (wc -c, grep -b) for a non-ASCII baseline. Absent -- everything in the baseline must be provenance-covered.",
              "type": ["string", "null"]
            }
          }
        },
        "adapter_config": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gutenberg_epub", "plain_text", "custom"],
          "properties": {
            "gutenberg_epub": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "properties": {
                "spine_overrides": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "enum": ["body", "footnote-defs", "front-back"]
                  }
                },
                "frontback_overrides": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "enum": ["translate", "regenerate", "omit"]
                  }
                }
              }
            },
            "plain_text": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": [
                "segmentation",
                "verse_detection",
                "verse_regex",
                "footnotes",
                "footnote_anchor_regex",
                "footnote_def_regex"
              ],
              "properties": {
                "segmentation": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["method", "blank_line_threshold", "heading_regex"],
                  "properties": {
                    "method": {
                      "type": "string",
                      "enum": ["blank_line_run", "heading_regex"]
                    },
                    "blank_line_threshold": {
                      "type": ["integer", "null"],
                      "minimum": 1
                    },
                    "heading_regex": {
                      "type": ["string", "null"],
                      "minLength": 1
                    }
                  }
                },
                "verse_detection": {
                  "type": "string",
                  "minLength": 1
                },
                "verse_regex": {
                  "type": ["string", "null"],
                  "minLength": 1
                },
                "footnotes": {
                  "type": "string",
                  "minLength": 1
                },
                "footnote_anchor_regex": {
                  "type": ["string", "null"],
                  "minLength": 1
                },
                "footnote_def_regex": {
                  "type": ["string", "null"],
                  "minLength": 1
                }
              }
            },
            "custom": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": ["extractor_path"],
              "properties": {
                "extractor_path": {
                  "type": ["string", "null"]
                }
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "format": { "const": "gutenberg_epub" }
            },
            "required": ["format"]
          },
          "then": {
            "properties": {
              "adapter_config": {
                "properties": {
                  "gutenberg_epub": { "type": "object" }
                },
                "required": ["gutenberg_epub"]
              }
            },
            "required": ["adapter_config"]
          }
        },
        {
          "if": {
            "properties": {
              "format": { "not": { "const": "gutenberg_epub" } }
            },
            "required": ["format"]
          },
          "then": {
            "properties": {
              "gutenberg_id": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "format": { "const": "plain_text" }
            },
            "required": ["format"]
          },
          "then": {
            "properties": {
              "adapter_config": {
                "properties": {
                  "plain_text": {
                    "type": "object",
                    "allOf": [
                      {
                        "if": {
                          "properties": {
                            "segmentation": {
                              "properties": {
                                "method": { "const": "blank_line_run" }
                              },
                              "required": ["method"]
                            }
                          },
                          "required": ["segmentation"]
                        },
                        "then": {
                          "properties": {
                            "segmentation": {
                              "properties": {
                                "blank_line_threshold": {
                                  "type": "integer",
                                  "minimum": 1
                                }
                              },
                              "required": ["blank_line_threshold"]
                            }
                          },
                          "required": ["segmentation"]
                        }
                      },
                      {
                        "if": {
                          "properties": {
                            "segmentation": {
                              "properties": {
                                "method": { "const": "heading_regex" }
                              },
                              "required": ["method"]
                            }
                          },
                          "required": ["segmentation"]
                        },
                        "then": {
                          "properties": {
                            "segmentation": {
                              "properties": {
                                "heading_regex": {
                                  "type": "string",
                                  "minLength": 1
                                }
                              },
                              "required": ["heading_regex"]
                            }
                          },
                          "required": ["segmentation"]
                        }
                      },
                      {
                        "properties": {
                          "verse_detection": {
                            "enum": ["none_confirmed", "regex"]
                          },
                          "footnotes": {
                            "enum": ["none_confirmed", "markdown_ref", "custom_regex"]
                          }
                        }
                      },
                      {
                        "if": {
                          "properties": {
                            "verse_detection": { "const": "regex" }
                          },
                          "required": ["verse_detection"]
                        },
                        "then": {
                          "properties": {
                            "verse_regex": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": ["verse_regex"]
                        }
                      },
                      {
                        "if": {
                          "properties": {
                            "verse_detection": { "const": "none_confirmed" }
                          },
                          "required": ["verse_detection"]
                        },
                        "then": {
                          "properties": {
                            "verse_regex": {
                              "type": "null"
                            }
                          }
                        }
                      },
                      {
                        "if": {
                          "properties": {
                            "footnotes": { "const": "custom_regex" }
                          },
                          "required": ["footnotes"]
                        },
                        "then": {
                          "properties": {
                            "footnote_anchor_regex": {
                              "type": "string",
                              "minLength": 1
                            },
                            "footnote_def_regex": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": ["footnote_anchor_regex", "footnote_def_regex"]
                        }
                      },
                      {
                        "if": {
                          "properties": {
                            "footnotes": { "not": { "const": "custom_regex" } }
                          },
                          "required": ["footnotes"]
                        },
                        "then": {
                          "properties": {
                            "footnote_anchor_regex": {
                              "type": "null"
                            },
                            "footnote_def_regex": {
                              "type": "null"
                            }
                          }
                        }
                      }
                    ]
                  }
                },
                "required": ["plain_text"]
              }
            },
            "required": ["adapter_config"]
          }
        },
        {
          "if": {
            "properties": {
              "format": { "const": "custom" }
            },
            "required": ["format"]
          },
          "then": {
            "properties": {
              "adapter_config": {
                "properties": {
                  "custom": { "type": "object" }
                },
                "required": ["custom"]
              }
            },
            "required": ["adapter_config"]
          }
        }
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language"],
      "properties": {
        "language": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "register_notes"],
          "properties": {
            "code": {
              "type": "string",
              "pattern": "^[a-z]{2}$"
            },
            "register_notes": {
              "type": "string"
            }
          }
        }
      }
    },
    "verse_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "threshold_lines"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "full_rhymed_plus_literal",
            "full_rhymed_only",
            "rhythmic_approximation",
            "mixed_by_length",
            "literal_only",
            "skip"
          ]
        },
        "threshold_lines": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": { "const": "mixed_by_length" }
            },
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "threshold_lines": {
                "type": "integer",
                "minimum": 1
              }
            },
            "required": ["threshold_lines"]
          }
        },
        {
          "if": {
            "properties": {
              "mode": { "not": { "const": "mixed_by_length" } }
            },
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "threshold_lines": {
                "type": "null"
              }
            },
            "required": ["threshold_lines"]
          }
        }
      ]
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effort", "max_fix_rounds", "batch_agent_cap"],
      "properties": {
        "effort": {
          "const": "high"
        },
        "max_fix_rounds": {
          "type": "integer",
          "minimum": 1
        },
        "batch_agent_cap": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "footnotes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apparatus_policy"],
      "properties": {
        "apparatus_policy": {
          "type": "string",
          "enum": ["translate_all", "preserve_source", "omit_apparatus", "body_refs_only"]
        }
      }
    },
    "glossary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research_mode"],
      "properties": {
        "research_mode": {
          "type": "string",
          "enum": ["live", "offline"]
        },
        "min_candidate_freq": {
          "type": "integer",
          "minimum": 1
        },
        "skeptic_pass": {
          "type": "object",
          "additionalProperties": false,
          "description": "RFC #215 Phase 2 structural-risk triage + adverse-only skeptic pass. OPT-IN and ADVISORY in 1.6.0 (disabled by default; the warn->block flip is deferred to Phase 3). When enabled, the W-step runs suspicion_scan.py -> skeptic_setup.py -> skeptic-pass-wf -> skeptic_report.py; the category-5 audit gate is unchanged and skeptic_report.py is a separate advisory command. This object is OUTSIDE profile_semantics_hash's allowlist, so adding/setting it never re-translates a converged segment. The `default:` values below MIRROR skeptic_constants.py's *_DEFAULT constants (profile_validate.py does not materialize schema defaults, so the constants are the real runtime defaults; a parity test asserts no drift). An enabled profile passes these as explicit CLI overrides via the W-step.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Master switch. When false (default) the skeptic W-step is skipped entirely and no existing output changes."
            },
            "windows_per_entity": {
              "type": "integer",
              "minimum": 1,
              "default": 8,
              "description": "Max whole-block citable windows fed to the skeptic per entity; exceeding it sets windows_truncated so the skeptic may honestly return insufficient_window/escalate."
            },
            "sample_cap": {
              "type": "integer",
              "minimum": 0,
              "default": 50,
              "description": "GLOBAL total for the `sampled` risk class (largest-remainder across category x confidence strata), not per-stratum."
            },
            "dispersion_threshold": {
              "type": "integer",
              "minimum": 1,
              "default": 12,
              "description": "`high_dispersion` fires when an entity's distinct-seg occurrence count reaches this."
            },
            "near_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.15,
              "description": "`near_merge` keeps pairs with (1 - difflib.SequenceMatcher.ratio()) <= this."
            },
            "near_cap": {
              "type": "integer",
              "minimum": 0,
              "default": 40,
              "description": "`near_merge` emits at most this many top pairs."
            },
            "near_pair_budget": {
              "type": "integer",
              "minimum": 1,
              "default": 5000,
              "description": "`near_merge` pre-enumeration materialization budget; exceeding it truncates deterministically WITH a logged annotation (never silent)."
            },
            "citation_block_types": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Override the block `type` tags that count as citation for `all_citation`. Omit to use the per-source.format default (gutenberg_epub/plain_text -> FN,QUOTE; custom/unknown -> all_citation DISABLED fail-safe)."
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["untranslated_sentinel"],
      "properties": {
        "untranslated_sentinel": {
          "type": "string",
          "minLength": 1
        },
        "conservation_hollow_floor": {
          "description": "Optional thresholds for validate_conservation.py's output-coverage v1 floor (#202, WARN-only): a block is flagged hollowed_output_block when its source word count is >= min_source_words AND its output word count is <= max_output_words. Absent -- both default (1, 0), i.e. 'non-empty source, empty output'. Absolute word counts, deliberately not a ratio -- see validate_assembled.py's own docstring on why a length-band is unsound across language pairs; a real calibrated band is deferred to v2.",
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "min_source_words": {
              "type": "integer",
              "minimum": 1
            },
            "max_output_words": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v1_scope", "destination"],
      "properties": {
        "v1_scope": {
          "type": "string",
          "enum": ["segment_drafts_and_audit", "assembled_book"]
        },
        "destination": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "enum": ["obsidian", "epub", "custom"]
        },
        "name_display": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "parenthetical_originals": {
              "type": "string",
              "enum": ["never", "first_occurrence"]
            }
          }
        },
        "index": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "person_grouping": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "adapter_config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "obsidian": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "properties": {
                "folders": {
                  "type": "object",
                  "additionalProperties": { "type": "string" },
                  "description": "Optional category -> folder catalog (e.g. {\"person\": \"people\", \"place\": \"places\"}) for the obsidian adapter's vault/<folder>/ note placement -- OPEN, per-project vocabulary (no enum): a category absent from this map routes to an 'other' folder, never a hard failure. See references/output-target-adapters/obsidian.md for documented preset examples."
                },
                "mentions_section": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true,
                      "description": "ON BY DEFAULT for output.target == 'obsidian' (an absent enabled key, or an absent mentions_section block, resolve to enabled (a literal null for enabled or mentions_section is schema-invalid and rejected by profile_validate, never a supported way to request the default) -- this 'default' annotation is documentation only, see the three runtime predicates in render_obsidian.py/assemble.py/validate_backlinks.py for the actual mechanism). When effective-enabled, the obsidian adapter emits a source-anchored '## Mentions' occurrence-index section (wrapped in reserved <!-- lt:mentions:begin/end --> markers) in each entity note, engages collision de-linking, and the advisory validate_backlinks.py W9 gate runs. Set to false explicitly to opt out. Outside profile_semantics_hash -- flipping it does NOT re-translate any converged segment, but DOES flip render_version (a rendered vault with an accepted baseline needs one operator --accept-baseline re-accept). See references/output-target-adapters/obsidian.md."
                    }
                  }
                }
              }
            },
            "epub": {
              "type": ["object", "null"]
            },
            "custom": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "properties": {
                "renderer_path": {
                  "type": ["string", "null"],
                  "pattern": "^[A-Za-z0-9._/-]+$",
                  "description": "Bare relative path (no '..' segments, no leading '/') to the co-designed custom output renderer, resolved as {durable_root}/scripts/custom_renderers/<value> by output_resolve.py. null means co-design hasn't happened yet -- output_resolve.py halts for co-design rather than silently swallowing the gap."
                }
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "index": {
                "properties": {
                  "person_grouping": { "const": true }
                },
                "required": ["person_grouping"]
              }
            },
            "required": ["index"]
          },
          "then": {
            "properties": {
              "index": {
                "properties": {
                  "enabled": { "const": true }
                },
                "required": ["enabled"]
              }
            },
            "required": ["index"]
          }
        }
      ]
    }
  },
  "patternProperties": {
    "^x_": {}
  },
  "additionalProperties": false,
  "required": [
    "profile_version",
    "project",
    "source",
    "target",
    "verse_policy",
    "engine",
    "footnotes",
    "glossary",
    "validation",
    "output"
  ]
}
