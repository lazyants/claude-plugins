def _missing_dep(pip_name: str, hint: str = "") -> None:
    suffix = f" ({hint})" if hint else ""
    print(
        f"ERROR: this plugin requires the '{pip_name}' Python package{suffix}.\n"
        f"Install with: pip install {pip_name}\n"
        f"(or: pip install -r requirements.txt from the literary-translator plugin directory)",
        file=sys.stderr,
    )
    sys.exit(1)


